# ════════════════════════════════════════════════════════════
# TenantOS — Environment Configuration
# Copy to .env and fill in your values before starting.
# ════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_VERSION=v1
APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tenantOS
POSTGRES_USER=tenantOS_user
POSTGRES_PASSWORD=StrongPassword123!
POSTGRES_SSL=false
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=20

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=RedisPassword123!
REDIS_DB=0
REDIS_TLS=false

# ── JWT — use long random strings in production ───────────────
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-random
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-different
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Security ──────────────────────────────────────────────────
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
SESSION_SECRET=change-me-session-secret-min-32-chars

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# ── AWS (optional — app works without these in dev) ───────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=tenantOS-assets
AWS_SES_FROM_EMAIL=noreply@yourdomain.com
AWS_CLOUDWATCH_GROUP=/tenantOS/production
AWS_SECRETS_MANAGER_ARN=

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_TO_CLOUDWATCH=false
